generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model SystemConfig {
  id              String  @id @default(uuid())
  appName         String  @default("nfood")
  logoUrl         String?
  splashUrl       String?
  backgroundUrl   String?
  backgroundBlur  Boolean @default(false)
  whatsappMessage String  @default("Hola, tu pedido está en estado: {{estado}}. Gracias por elegirnos!")
  isStoreOpen     Boolean @default(true)
  closedMessage   String  @default("Lo sentimos, actualmente nuestro local se encuentra cerrado.")
  
  primaryColor    String  @default("#f97316") // orange-500
  secondaryColor  String  @default("#9333ea") // purple-600
  
  splashEnabled   Boolean @default(false)
  splashDuration  Int     @default(3) // seconds
  
  welcomeBalloonEnabled  Boolean @default(false)
  welcomeBalloonText     String  @default("¡Te damos la bienvenida a nuestra PWA!")
  welcomeBalloonDuration Int     @default(5) // seconds
  
  deliveryCost    Float   @default(0)
  globalDiscount  Float   @default(0) // percentage 0-100
  
  paymentCash     Boolean @default(true)
  paymentMp       Boolean @default(true)
  autoPrintTickets Boolean @default(true)

  isRouletteActive Boolean @default(false)
  rouletteCost     Int     @default(100)

  updatedAt       DateTime @updatedAt
}

model RoulettePrize {
  id              String  @id @default(uuid())
  name            String
  probability     Float
  
  type            String  // PRODUCT, PERCENT, AMOUNT
  value           Float?  
  productId       String? 
  
  bgColor         String  @default("#f97316")
  textColor       String  @default("#ffffff")
  
  product         Product? @relation(fields: [productId], references: [id])
}

model BusinessHour {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 0 = Sunday, 1 = Monday...
  openTime  String   // HH:mm
  closeTime String   // HH:mm
  isOpen    Boolean  @default(true)
}

model DeliveryTimeSlot {
  id        String   @id @default(uuid())
  time      String   // e.g. "21:00"
  capacity  Int      // Total initial cupos
  available Int      // Current real-time available cupos
  isActive  Boolean  @default(true)
  sequence  Int      @default(0) // Chronological sorting
}

model Messenger {
  id        String  @id @default(uuid())
  name      String
  phone     String
  isActive  Boolean @default(true)
  orders    Order[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  isActive Boolean   @default(true)
  sequence Int       @default(0)
  products Product[]
  ingredients IngredientCategory[]
}

model Product {
  suggestedCost Float @default(0)
  id          String       @id @default(uuid())
  name        String
  categoryId  String?
  basePrice   Float
  description String?
  imageUrl    String?
  showImage   Boolean      @default(true)
  isActive    Boolean      @default(true)
  isCombo     Boolean      @default(false)
  
  allowHalf    Boolean      @default(false)
  onlyHalf     Boolean      @default(false)
  allowRemoveIngredients Boolean @default(true)
  
  points       Int          @default(0)
  
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  ingredients ProductIngredient[]
  extras      ProductExtra[]
  orderItems  OrderItem[]
  
  orderItemsAsSecondHalf OrderItem[] @relation("SecondHalf")
  comboItemsConfig   ProductComboItem[] @relation("ComboToItems")
  partOfCombosConfig ProductComboItem[] @relation("ItemToCombo")

  orderItemsAsComboItem OrderItemComboItem[]
  roulettePrizes        RoulettePrize[]
}

model Ingredient {
  id              String  @id @default(uuid())
  name            String
  isActive        Boolean @default(true)

  purchaseVolume   String?
  purchasePrice    Float    @default(0)
  yieldUnits       Float    @default(1)
  costPerUnit      Float    @default(0)
  stock            Float    @default(0)
  
  categories      IngredientCategory[]
  products        ProductIngredient[]
  removedInOrders OrderItemRemovedIngredient[]
  comboRemovedInOrders OrderItemComboRemovedIngredient[]
}

model IngredientCategory {
  ingredientId String
  categoryId   String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  category     Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([ingredientId, categoryId])
}

model ProductIngredient {
  productId    String
  ingredientId String
  isRemovable  Boolean @default(true)
  quantity     Float   @default(1)
  
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@id([productId, ingredientId])
}

model Extra {
  id          String         @id @default(uuid())
  name        String
  price       Float
  isActive    Boolean        @default(true)
  products    ProductExtra[]
  orderExtras OrderItemExtra[]
}

model ProductExtra {
  productId String
  extraId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  extra     Extra   @relation(fields: [extraId], references: [id], onDelete: Cascade)

  @@id([productId, extraId])
}

model ProductComboItem {
  id        String  @id @default(uuid())
  comboId   String
  productId String
  quantity  Int     @default(1)
  
  combo     Product @relation("ComboToItems", fields: [comboId], references: [id], onDelete: Cascade)
  product   Product @relation("ItemToCombo", fields: [productId], references: [id], onDelete: Restrict)
}

model Order {
  id               String   @id @default(uuid())
  clientName       String
  clientPhone      String
  needsDelivery    Boolean
  deliveryAddress  String?
  deliveryTime     String?
  status           String   @default("NEW") // NEW, IN_PROCESS, FINISHED, DELIVERED, CANCELLED
  paymentMethod    String   // CASH, MERCADOPAGO
  paymentStatus    String   @default("PENDING") // PENDING, PAID, FAILED
  mpPreferenceId   String?
  total            Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messengerId      String?
  messenger        Messenger? @relation(fields: [messengerId], references: [id])

  clientId         String?
  client           Client?    @relation(fields: [clientId], references: [id])
  earnedPoints     Int        @default(0)

  items            OrderItem[]
  history          OrderHistory[]
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  quantity        Int
  unitPrice       Float
  subtotal        Float
  notes           String?

  isHalfAndHalf        Boolean @default(false)
  secondHalfProductId  String?
  secondHalfProduct    Product? @relation("SecondHalf", fields: [secondHalfProductId], references: [id], onDelete: Restrict)

  order                 Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               Product                      @relation(fields: [productId], references: [id], onDelete: Restrict)
  removedIngredients    OrderItemRemovedIngredient[]
  addedExtras           OrderItemExtra[]
  comboItems            OrderItemComboItem[]
}

model OrderItemComboItem {
  id          String @id @default(uuid())
  orderItemId String
  productId   String
  
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  removedIngredients OrderItemComboRemovedIngredient[]
}

model OrderItemComboRemovedIngredient {
  comboItemId  String
  ingredientId String
  
  comboItem    OrderItemComboItem @relation(fields: [comboItemId], references: [id], onDelete: Cascade)
  ingredient   Ingredient         @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@id([comboItemId, ingredientId])
}

model OrderItemRemovedIngredient {
  orderItemId  String
  ingredientId String

  orderItem    OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Restrict)

  @@id([orderItemId, ingredientId])
}

model OrderItemExtra {
  orderItemId String
  extraId     String
  price       Float

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  extra       Extra     @relation(fields: [extraId], references: [id], onDelete: Restrict)

  @@id([orderItemId, extraId])
}

model OrderHistory {
  id        String   @id @default(uuid())
  orderId   String
  status    String
  createdAt DateTime @default(now())
  
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Client {
  id        String   @id @default(uuid())
  phone     String   @unique
  password  String
  name      String?
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  orders    Order[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  clientId  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

